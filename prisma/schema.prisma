generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tabela de Usuários
model Usuario {
  id         String      @id @default(uuid())
  nome       String
  email      String      @unique
  senha      String
  role       String      @default("USER")
  
  bancos     Banco[]
  transacoes Transacao[]
  eventos    Evento[]

  @@map("usuarios")
}

// Tabela de Bancos
model Banco {
  id               String      @id @default(uuid())
  nome             String
  cor              String?     @default("#2f855a") // Cor padrão ajustada
  
  // Campos Detalhados
  agencia          String?
  conta            String?
  saldoInicial     Float       @default(0)
  dataSaldoInicial DateTime?   // NOME CORRIGIDO (era dataSaldo)
  inativo          Boolean     @default(false)

  usuarioId        String
  usuario          Usuario     @relation(fields: [usuarioId], references: [id])
  transacoes       Transacao[]

  @@map("bancos")
}

// Tabela de Transações (Entradas e Saídas)
model Transacao {
  id             String    @id @default(uuid())
  fornecedor     String?
  descricao      String
  valor          Float
  valorOriginal  Float?
  juros          Float?    @default(0)
  desconto       Float?    @default(0)
  tipo           String    // RECEITA ou DESPESA
  categoria      String?
  status         String    @default("PENDENTE")
  parcelas       Int?      @default(1)
  parcelaInfo     String?
  
  // Datas
  data           DateTime  @default(now())
  dataPagamento  DateTime?
  dataVencimento DateTime?
  formaPagamento String?

  // Relacionamentos
  bancoId        String?
  banco          Banco?    @relation(fields: [bancoId], references: [id])
  usuarioId      String?
  usuario        Usuario?  @relation(fields: [usuarioId], references: [id])

  @@map("transacoes")
}

// Tabela de Agenda/Rotina
model Evento {
  id        String   @id @default(uuid())
  titulo    String
  descricao String?  
  local     String?  
  data      DateTime
  tipo      String   @default("TAREFA")
  concluido Boolean  @default(false)
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
}